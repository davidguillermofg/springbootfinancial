{
  "info": {
    "name": "Microservicios Cliente y Cuenta",
    "description": "Validación de endpoints. Base URL Cliente: http://{{servidor}}:8080 | Cuenta: http://{{servidor}}:8081",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "servidor", "value": "localhost" }
  ],
  "item": [
    {
      "name": "Cliente",
      "item": [
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://{{servidor}}:8080/clientes"
          }
        },
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"098254785\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            },
            "url": "http://{{servidor}}:8080/clientes"
          }
        },
        {
          "name": "Obtener cliente por id",
          "request": {
            "method": "GET",
            "url": "http://{{servidor}}:8080/clientes/1"
          }
        },
        {
          "name": "Actualizar cliente (PUT)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"098254785\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            },
            "url": "http://{{servidor}}:8080/clientes/1"
          }
        },
        {
          "name": "Eliminar cliente",
          "request": {
            "method": "DELETE",
            "url": "http://{{servidor}}:8080/clientes/1"
          }
        }
      ]
    },
    {
      "name": "Cuenta",
      "item": [
        {
          "name": "Listar cuentas",
          "request": {
            "method": "GET",
            "url": "http://{{servidor}}:8081/cuentas"
          }
        },
        {
          "name": "Crear cuenta",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorros\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": 1\n}"
            },
            "url": "http://{{servidor}}:8081/cuentas"
          }
        },
        {
          "name": "Obtener cuenta por id",
          "request": {
            "method": "GET",
            "url": "http://{{servidor}}:8081/cuentas/1"
          }
        },
        {
          "name": "Actualizar cuenta (PUT)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorros\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": 1\n}"
            },
            "url": "http://{{servidor}}:8081/cuentas/1"
          }
        }
      ]
    },
    {
      "name": "Movimientos",
      "item": [
        {
          "name": "Listar movimientos por cuenta",
          "request": {
            "method": "GET",
            "url": "http://{{servidor}}:8081/movimientos?cuentaId=1"
          }
        },
        {
          "name": "Registrar movimiento (depósito)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuentaId\": 1,\n  \"tipoMovimiento\": \"Deposito\",\n  \"valor\": 600\n}"
            },
            "url": "http://{{servidor}}:8081/movimientos"
          }
        },
        {
          "name": "Registrar movimiento (retiro)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuentaId\": 1,\n  \"tipoMovimiento\": \"Retiro\",\n  \"valor\": -575\n}"
            },
            "url": "http://{{servidor}}:8081/movimientos"
          }
        },
        {
          "name": "Obtener movimiento por id",
          "request": {
            "method": "GET",
            "url": "http://{{servidor}}:8081/movimientos/1"
          }
        }
      ]
    },
    {
      "name": "Reportes",
      "item": [
        {
          "name": "Estado de cuenta",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://{{servidor}}:8081/reportes?cliente=1&nombreCliente=Jose Lema&fechaDesde=2022-01-01&fechaHasta=2022-12-31",
              "host": ["http://{{servidor}}:8081"],
              "path": ["reportes"],
              "query": [
                {"key": "cliente", "value": "1"},
                {"key": "nombreCliente", "value": "Jose Lema"},
                {"key": "fechaDesde", "value": "2022-01-01"},
                {"key": "fechaHasta", "value": "2022-12-31"}
              ]
            }
          }
        }
      ]
    }
  ]
}
